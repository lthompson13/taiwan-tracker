# =============================================================================
# Environment Variables Template
# =============================================================================
# Copy this file to `.env` (in the directory your server reads it from, e.g.
# `server/.env`) and fill in real values. Do NOT commit `.env` — it is listed
# in .gitignore.
# =============================================================================

# -----------------------------------------------------------------------------
# Required
# -----------------------------------------------------------------------------

# Clerk authentication keys.
# Get these from https://dashboard.clerk.com → your app → API Keys.
# VITE_CLERK_PUBLISHABLE_KEY goes in client/.env.local (frontend, baked in at build time).
# CLERK_SECRET_KEY goes in Railway dashboard environment variables (server-side only).
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Google Cloud Translate API key.
# Used by the server to call the Google Cloud Translation API.
# Create one in Google Cloud Console:
#   https://console.cloud.google.com/apis/credentials
# Make sure the "Cloud Translation API" is enabled on the project that owns
# the key, and restrict the key to that API for safety.
GOOGLE_TRANSLATE_API_KEY=your-google-translate-api-key-here


# -----------------------------------------------------------------------------
# Optional
# -----------------------------------------------------------------------------

# PostgreSQL connection string — enables all database features (bill summaries
# stored in DB, subscriber management, future user accounts).
# Add a PostgreSQL service to your Railway project; Railway auto-injects
# DATABASE_URL into the same project's environment.
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Secret token protecting the /api/admin/* endpoints.
# Set to any long random string (e.g. openssl rand -hex 32).
# Required to use the admin API for managing summaries and subscribers.
# ADMIN_SECRET=your-secret-here

# Upstash Redis REST credentials — enables persistent translation cache.
# Without these, the translation cache is in-memory only and resets on every
# server restart/redeploy (driving up Google Translate API costs).
# Create a free Redis database at https://console.upstash.com and copy the
# REST URL and token from the database's "REST API" tab.
# UPSTASH_REDIS_REST_URL=https://your-endpoint.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-token-here

# Scheduled sync overrides (all optional — defaults shown).
# SYNC_CRON=0 18 * * *     # cron schedule in UTC (default = 2 AM Taiwan time)
# SYNC_TERM=11              # legislative term to sync
# SYNC_MAX_PAGES=200        # max pages per daily run (~4,000 bills)

# Port the backend server listens on.
# Defaults to 3001 if unset. Override only if 3001 is already in use locally
# or your hosting provider injects a different port.
# PORT=3001
