# =============================================================================
# Environment Variables Template
# =============================================================================
# Copy this file to `.env` (in the directory your server reads it from, e.g.
# `server/.env`) and fill in real values. Do NOT commit `.env` — it is listed
# in .gitignore.
# =============================================================================

# -----------------------------------------------------------------------------
# Required
# -----------------------------------------------------------------------------

# Google Cloud Translate API key.
# Used by the server to call the Google Cloud Translation API.
# Create one in Google Cloud Console:
#   https://console.cloud.google.com/apis/credentials
# Make sure the "Cloud Translation API" is enabled on the project that owns
# the key, and restrict the key to that API for safety.
GOOGLE_TRANSLATE_API_KEY=your-google-translate-api-key-here


# -----------------------------------------------------------------------------
# Optional
# -----------------------------------------------------------------------------

# Port the backend server listens on.
# Defaults to 3001 if unset. Override only if 3001 is already in use locally
# or your hosting provider injects a different port.
# PORT=3001
